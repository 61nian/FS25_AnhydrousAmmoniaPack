<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="silo" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://validation.gdn.giants-software.com/xml/fs22/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_anhydrousTank</name>
        <specs>
            <fillTypes>liquidFertilizer ANHYDROUS</fillTypes>
        </specs>
        <functions>
            <function>$l10n_function_anhydrousTank</function>
        </functions>
        <image>store/store_anhydroustank.png</image>
        <price>25000</price>
        <dailyUpkeep>100</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>silos</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>containers</tab>
        </brush>
    </storeData>
    <base>
        <filename>i3D/horizontal_tank.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>
    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="0>1|1" endNode="0>1|1|0"/>
        </testAreas>
    </placement>
    <clearAreas>
        <clearArea startNode="0>1|0" widthNode="0>1|0|0" heightNode="0>1|0|1"/>
    </clearAreas>
    <leveling requireLeveling="true" maxSmoothDistance="1" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="0>1|0" widthNode="0>1|0|0" heightNode="0>1|0|1"/>
        </levelAreas>
    </leveling>
    <indoorAreas/>
    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="0>1|0|0" endNode="0>1|0|1"/>
    </tipOcclusionUpdateAreas>
    <ai>
        <updateAreas>
            <updateArea startNode="0>1|0|0" endNode="0>1|0|1"/>
        </updateAreas>
    </ai>
    <infoTrigger triggerNode="0>4|4"/>
    <silo playerActionTrigger="0>4|5">
        <loadingStation node="0>4|1|0|0|0" supportsExtension="false">
            <loadTrigger triggerNode="0>4|1|0|0|0" aiNode="0>4|1|0|0|1" fillTypes="liquidFertilizer ANHYDROUS" fillLitersPerSecond="200"/>
        </loadingStation>
        <unloadingStation supportsExtension="false">
            <unloadTrigger fillTypes="liquidFertilizer ANHYDROUS" aiNode="0>4|0|0|0|1" exactFillRootNode="0>4|0|0|0|0"/>
        </unloadingStation>
        <storages>
            <storage node="0>4|2" fillTypes="liquidFertilizer ANHYDROUS" capacity="40000" supportsMultipleFillTypes="true" isExtension="false"/>
        </storages>
    </silo>
    <hotspots>
        <hotspot type="LOADING" linkNode="0>4|3"/>
    </hotspots>
	
	<animatedObjects>
		<animatedObject saveId="directionChange" >
		    <animation  duration="2">
                <part node="0|4">
                    <keyFrame time="0.000" visibility="true"/>
                    <keyFrame time="0.030" visibility="true"/>
                    <keyFrame time="0.031" visibility="false"/>
                    <keyFrame time="1.000" visibility="false"/>
                </part>
                <part node="0|5">
                    <keyFrame time="0.000" visibility="false"/>
                    <keyFrame time="0.060" visibility="false"/>
                    <keyFrame time="0.091" visibility="true"/>
                    <keyFrame time="1.000" visibility="true"/>
                </part>
            </animation>
			
			
			<controls triggerNode="0>4|9|0" negAction="ACTIVATE_HANDTOOL" posAction="THROW_OBJECT" posText="action_nextSign" negText="action_prevSign"  />
	</animatedObject>
	</animatedObjects>	
	
	
    <triggerMarkers>
        <triggerMarker node="0>4|6" filename="$data/shared/assets/marker/markerIconLoad.i3d" />
        <triggerMarker node="0>4|7" filename="$data/shared/assets/marker/markerIconUnload.i3d" />
        <triggerMarker node="0>4|5|0" filename="$data/shared/assets/marker/markerIconWrench.i3d" />
		<triggerMarker node="0>4|8" filename="$data/shared/assets/marker/markerIconExclamationMark.i3d" />
    </triggerMarkers>
</placeable>